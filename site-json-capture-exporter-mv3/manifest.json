{
  "manifest_version": 3,
  "name": "Site JSON Capture Exporter",
  "version": "1.0.1",
  "description": "Captures selected API responses on a chosen site and downloads them as JSON files when the user requests it.",
  "permissions": [],
  "host_permissions": [
    "https://participant.empower-retirement.com/*"
  ],
  "action": {
    "default_title": "JSON Capture Exporter",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://participant.empower-retirement.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page_hook.js"],
      "matches": ["https://participant.empower-retirement.com/*"]
    }
  ]
}